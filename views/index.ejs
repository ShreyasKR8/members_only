<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Members only</title>
</head>

<body>
    <h1>Members only</h1>
    <% if(locals.currentUser == null) { %>
        <a href="auth/register">Register</a>
        <a href="auth/login">Login</a>
    <% } else if(!locals.currentUser.is_member) { %>
        <a href="/join-club">Join the club</a>
    <% } %>
    
</body>

</html>