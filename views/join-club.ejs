<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Members only</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/images/group.png">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <main class="auth-page">
        <section class="panel">
            <p class="eyebrow">Membership test</p>
            <h1 class="page-title">Join the Club</h1>
            <p class="page-copy">One question stands between you and the secret author list.</p>

            <div class="question-box">
                I sleep most of the day, knock things off tables for no reason, and secretly run the internet. What am I?
            </div>

            <form method="POST" action="join-club">
                <div class="field">
                    <label for="passcode">Answer</label>
                    <input id="passcode" type="text" name="passcode" placeholder="Type your answer here" required />
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary" type="submit">Join now</button>
                    <a class="btn btn-secondary" href="/">Back to home</a>
                </div>
            </form>
        </section>
    </main>
    <footer class="site-footer">
        <a href="https://www.flaticon.com/free-icons/members" target="_blank" title="members icons">Members icons created by Irfansusanto20 - Flaticon</a>
    </footer>
</body>
</html>
